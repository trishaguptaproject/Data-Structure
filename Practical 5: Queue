import os

class Queue:
    def __init__(self, max_size):
        self.queue = []
        self.max_size = max_size

    def is_empty(self):
        return len(self.queue) == 0

    def is_full(self):
        return len(self.queue) >= self.max_size

    def enqueue(self, item):
        if self.is_full():
            print("\nQueue is Full! Cannot enqueue.")
        else:
            self.queue.append(item)
            print(f"\n'{item}' added successfully.")

    def dequeue(self):
        if self.is_empty():
            print("\nQueue is Empty! Cannot dequeue.")
        else:
            item = self.queue.pop(0)
            print(f"\nRemoved Item: {item}")

    def peek(self):
        if self.is_empty():
            print("\nQueue is Empty!")
        else:
            print(f"\nFront Item: {self.queue[0]}")

    def traverse(self):
        if self.is_empty():
            print("\nQueue is Empty!")
        else:
            print("\nQueue Elements:")
            for item in self.queue:
                print("->", item)

    def display_list(self):
        if self.is_empty():
            print("\nQueue is Empty!")
        else:
            print("\nCurrent Queue")
            print("-" * 30)
            for i, item in enumerate(self.queue, start=1):
                print(f"{i}. {item}")
            print("-" * 30)

    def clear_queue(self):
        self.queue.clear()
        print("\nQueue Cleared Successfully!")

    def size(self):
        print(f"\nCurrent Queue Size: {len(self.queue)}")


